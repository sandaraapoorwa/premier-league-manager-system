# Routes
# This file defines all application routes
# ~~~~

# Home Route
GET     /                           controllers.ApplicationController.home()

# Static assets
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)

# Club APIs
POST    /clubs                      controllers.ClubController.addClub(request: Request)
GET     /clubs                      controllers.ClubController.getClubs()

POST    /matches      controllers.MatchController.createMatch(request: Request)
GET     /matches      controllers.MatchController.getMatches()

GET     /league     controllers.LeagueController.getTable()

POST    /fixtures     controllers.FixtureController.generateFixtures()

POST    /simulate     controllers.SimulationController.simulateMatches()