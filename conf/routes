# Routes
# This file defines all application routes
# ~~~~

# Home Route
GET     /                           controllers.ApplicationController.home()

# Static assets
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)

POST    /matches      controllers.MatchController.createMatch(request: Request)
GET     /matches      controllers.MatchController.getMatches()

GET     /league     controllers.LeagueController.getTable()

POST    /fixtures     controllers.FixtureController.generateFixtures()

POST    /simulate     controllers.SimulationController.simulateMatches()

POST    /players      controllers.PlayerController.addPlayer(request: Request)
GET     /players      controllers.PlayerController.getPlayers()

POST    /play-season     controllers.SeasonController.playSeason()

POST    /reset-season     controllers.ResetSeasonController.resetSeason()

GET     /teams      controllers.TeamController.getTeams()

POST   /fixtures   controllers.FixtureController.generateFixtures()



GET    /matchdays/status          controllers.MatchdayController.getStatus()
GET    /matchday/:id              controllers.MatchdayController.getMatchday(id: Int)
POST   /matchday/:id/simulate     controllers.MatchdayController.simulateMatchday(id: Int)